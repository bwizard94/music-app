# ─── Supabase ─────────────────────────────────────────────────────────────────
# Your project URL from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your anon/public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Optional: Service Role (server-side only, never expose to browser) ───────
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Optional: App URL (used for OG metadata and share links) ─────────────────
# NEXT_PUBLIC_APP_URL=https://stagefront.app
